{
  "name": "@gmod/bgzf-filehandle",
  "version": "6.0.12",
  "description": "read from a compressed bgzip file (with .gzi) as if it were uncompressed",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/bgzf-filehandle.git"
  },
  "type": "module",
  "types": "./esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./esm/index.d.ts",
      "import": "./esm/index.js"
    }
  },
  "files": [
    "esm",
    "src"
  ],
  "scripts": {
    "test": "vitest",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "benchonly": "vitest bench",
    "bench": "./scripts/build-both-branches.sh \"$BRANCH1\" \"$BRANCH2\" && vitest bench",
    "clean": "rimraf esm",
    "prebuild": "yarn clean",
    "format": "prettier --write .",
    "build:wasm": "./scripts/build-wasm.sh",
    "build:esm": "tsc --outDir esm",
    "postbuild:esm": "cp src/wasm/bgzf_wasm_bg.wasm esm/wasm/",
    "build": "yarn build:wasm && yarn build:esm",
    "preversion": "yarn test --run && yarn build",
    "postversion": "git push --follow-tags"
  },
  "keywords": [
    "bionode",
    "biojs"
  ],
  "dependencies": {
    "@jbrowse/quick-lru": "^7.3.5",
    "generic-filehandle2": "^2.1.4",
    "pako-esm2": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2",
    "esbuild": "^0.25.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
